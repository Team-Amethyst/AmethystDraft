{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": ["PORT"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "env": [
        "NODE_ENV",
        "CORS_ORIGIN",
        "MONGO_URI",
        "JWT_SECRET",
        "AMETHYST_API_BASE_URL",
        "AMETHYST_API_URL",
        "AMETHYST_API_KEY",
        "PLAYER_API_TEST_KEY",
        "AMETHYST_CONTRACT_TEST",
        "AMETHYST_ENGINE_TIMEOUT_MS",
        "LOG_ENGINE_VALUATION_DEBUG"
      ]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["PORT", "VITE_PORT", "VITE_API_URL"]
    }
  }
}
