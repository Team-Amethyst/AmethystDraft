# Copy to .env and fill in values. Never commit real secrets.

MONGO_URI=
JWT_SECRET=

# Optional: logical service label for logs (default draftroom-api, or AWS_APPRUNNER_SERVICE_ID when set).
# SERVICE_NAME=draftroom-api

# Optional: MongoDB driver pool cap per API process (default 10). Lower further when many
# App Runner tasks / replicas share one Atlas cluster so total connections stay under limit.
# MONGODB_MAX_POOL_SIZE=5

# Browser origins allowed to call this API with credentials (cookies / Authorization).
# Comma-separated. Use https in production. List only hostnames that actually load the SPA
# (Origin header); if www only redirects to apex before the app runs, apex alone is enough.
# Team reference value also lives in GitHub Actions variable CORS_ORIGIN (mirror on App Runner).
# Production example (custom domain + S3 static website endpoint for direct bucket URL):
# CORS_ORIGIN=https://draftroom.uk,https://www.draftroom.uk,http://amethyst-web-prod.s3-website-us-east-1.amazonaws.com
CORS_ORIGIN=http://localhost:5173

# Engine (AmethystAPI) — server-only. Never put AMETHYST_API_KEY in apps/web or VITE_*.
# Runbook name for origin: AMETHYST_API_BASE_URL (no trailing slash required; stripped).
AMETHYST_API_BASE_URL=
# Legacy alias; used if AMETHYST_API_BASE_URL is empty.
AMETHYST_API_URL=
AMETHYST_API_KEY=
PLAYER_API_TEST_KEY=

# Optional: separate Bearer secret for POST /api/internal/news-signals/hook (Engine ingest).
# If unset, the hook accepts Authorization: Bearer <AMETHYST_API_KEY> (same key Draft uses toward Engine).
INTERNAL_WEBHOOK_SECRET=

# Optional: Redis URL for @socket.io/redis-adapter when running multiple Draft API instances
# (Engine webhooks and browser Socket.IO may hit different tasks). Example: redis://localhost:6379
# REDIS_URL=
