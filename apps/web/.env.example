# Copy to .env.local for local dev. Never commit real secrets.

# AmethystDraft API (Express BFF), not the Engine URL.
# Production builds: set via CI (e.g. VITE_API_URL GitHub Actions variable).
VITE_API_URL=http://localhost:3000

# News Socket.IO uses HTTP long-polling only (see useNewsSignalsRealtime) so App Runner
# and similar proxies work without a working WebSocket upgrade path.

# Do not add AMETHYST_API_KEY or Engine origins here — those are server-only in apps/api.
